{
  "expo": {
    "name": "Tagora",
    "slug": "tagora",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "tagora",
    "newArchEnabled": true,
    "backgroundColor": "#FFFFFF",
    "splash": {
      "backgroundColor": "#0F1B3D",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.tagora.mobile",
      "associatedDomains": [
        "applinks:tagora.link",
        "applinks:www.tagora.link"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Sticker'ınızı hesabınıza eşleştirmek için QR kodu okumamız gerekiyor.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "app.tagora.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0F1B3D"
      },
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "tagora.link",
              "pathPrefix": "/s/"
            },
            {
              "scheme": "https",
              "host": "www.tagora.link",
              "pathPrefix": "/s/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Tagora sticker QR kodunuzu tarayabilmek için kameraya erişim gerekiyor."
        }
      ],
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#0F1B3D",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2d66fb45-da7c-4b19-b6e7-f061c7d32a39"
      }
    },
    "owner": "omerkilinc"
  }
}
