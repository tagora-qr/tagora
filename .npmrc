# pnpm ayarları
# Expo + React Native monorepo desteği için hoisted node-linker gerekli:
# https://docs.expo.dev/guides/monorepos/#pnpm-configuration
node-linker=hoisted

# Peer dependency auto-install (Next.js + Expo için)
auto-install-peers=true

# Strict peer dep uyarılarını sessize al
strict-peer-dependencies=false
