# =====================================================
# TAGORA ENVIRONMENT VARIABLES
# Bu dosyayı .env.local olarak kopyala ve değerleri doldur
# =====================================================

# --- Supabase ---
# https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY   # SADECE SERVER tarafında

# --- App URL ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Mobil App Store URL'leri (yayına geçince doldur) ---
# Boş bırakırsan "Yakında" durumu gösterilir
# NEXT_PUBLIC_APP_STORE_URL=https://apps.apple.com/tr/app/tagora/id0000000000
# NEXT_PUBLIC_GOOGLE_PLAY_URL=https://play.google.com/store/apps/details?id=com.tagora.qr

# --- Site Configuration ---
NEXT_PUBLIC_SITE_NAME=Tagora
NEXT_PUBLIC_DEFAULT_LOCALE=tr

# --- iyzico (TR ödeme — v1) ---
# IYZICO_API_KEY=
# IYZICO_SECRET_KEY=
# IYZICO_BASE_URL=https://sandbox-api.iyzipay.com   # prod: https://api.iyzipay.com

# --- Netgsm SMS OTP (v1) ---
# NETGSM_USERCODE=
# NETGSM_PASSWORD=
# NETGSM_HEADER=

# --- Analytics (PostHog EU) ---
# Product analytics + funnel + session replay. KVKK: EU region.
# Public key — client bundle'a expose olur, güvenli.
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXX
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Error tracking (Sentry) ---
# Client + server + edge error tracking. EU region.
# DSN public — client bundle'da expose olur, güvenli.
NEXT_PUBLIC_SENTRY_DSN=https://XXX@YYY.ingest.de.sentry.io/ZZZ
# Source map upload için (opsiyonel — yoksa build başarısız olmaz, sadece stack minified kalır):
# SENTRY_ORG=tagora
# SENTRY_PROJECT=tagora-web
# SENTRY_AUTH_TOKEN=sntrys_XXXXXXXXXXXXXXXX

# --- Brevo Email (transactional) ---
# Sipariş onay + kargo bildirimi + magic link auth email için.
# Supabase Auth SMTP config'inde Brevo SMTP relay kullanılıyor.
# Vercel'de Production + Preview ortamına eklenmesi gerek.
# https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-XXXXXXXXXXXXXXXX
# Opsiyonel — override etmezsen default değerler kullanılır:
# BREVO_FROM_EMAIL=bildirim@tagora.com.tr
# BREVO_FROM_NAME=Tagora
# BREVO_REPLY_TO=destek@tagora.com.tr
